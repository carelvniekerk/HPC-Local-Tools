#!/bin/zsh

# Tool name: hpc

export PYTHON_INTERPRETER="${HPC_TOOLS_DIR}/.venv/bin/python3"
eval "$(${PYTHON_INTERPRETER} ${HPC_TOOLS_DIR}/hpc_tools/constants.py --hpc_name ${ACTIVE_HPC_NAME})"

# Command Aliases
alias sync_project_command="${PYTHON_INTERPRETER} ${HPC_TOOLS_DIR}/hpc_tools/sync_project.py --hpc_name ${ACTIVE_HPC_NAME}"
alias run_command="${PYTHON_INTERPRETER} ${HPC_TOOLS_DIR}/hpc_tools/submit.py --hpc_name ${ACTIVE_HPC_NAME}"
alias status_command="ssh ${HPC_TOOLS_LOGIN_NODE} -t \"bash -ci 'base && clear && qs'\""
alias start_interactive_command="ssh ${HPC_TOOLS_LOGIN_NODE} -t \"bash -ci 'base && clear && qi'\""
alias connect_to_logs_command="ssh ${HPC_TOOLS_LOGIN_NODE} -t \"bash -ci 'base && clear && home && job_log'\""
alias sync_results_command="${PYTHON_INTERPRETER} ${HPC_TOOLS_DIR}/hpc_tools/sync_results.py --hpc_name ${ACTIVE_HPC_NAME}"

# Alias for syncing local huggingface models with HPC
eval $(echo "export HPC_HUGGINGFACE_CACHE=\$${ACTIVE_HPC_NAME}_HUGGINGFACE_CACHE")
alias sync_hf_command="rsync -avz --delete --progress ${HOME}/.cache/huggingface/ ${HPC_TOOLS_STORAGE_NODE}:${HPC_HUGGINGFACE_CACHE}"

# Load the log file environment variables
eval $(echo "export JOB_LOGS_REMOTE_DIR=\$${ACTIVE_HPC_NAME}_JOB_LOGS_PATH")
export JOB_LOGS_LOCAL_DIR="${JOB_LOGS_LOCAL_DIR:-${HOME}/Projects/hpc_job_logs}"
export JOB_LOGS_BACKUP_LOCAL_DIR="${JOB_LOGS_BACKUP_LOCAL_DIR:-${HOME}/Projects/hpc_job_logs_backup}"

sync_job_logs() {
    echo "Syncing job logs from the HPC to the local machine at ${JOB_LOGS_LOCAL_DIR}"

    if [[ ! -d "${JOB_LOGS_LOCAL_DIR}" ]]; then
        mkdir -p "${JOB_LOGS_LOCAL_DIR}"
    fi

    rsync \
        -avz --delete --progress \
        "${HPC_TOOLS_STORAGE_NODE}:${JOB_LOGS_REMOTE_DIR}/" \
        "${JOB_LOGS_LOCAL_DIR}"
}

backup_job_logs() {
    # Ensure JOB_LOGS_BACKUP_LOCAL_DIR is set
    if [[ -z "${JOB_LOGS_BACKUP_LOCAL_DIR}" ]]; then
        echo "Error: JOB_LOGS_BACKUP_LOCAL_DIR is not set. Please define this variable."
        return 1
    fi

    # Ensure hilbert_job_logs exists and is not empty before attempting to back it up
    if [[ ! -d "${JOB_LOGS_LOCAL_DIR}" ]]; then
        echo "Error: JOB_LOGS_LOCAL_DIR does not exist or is not set correctly."
        return 1
    fi

    if [[ -z "$(ls -A ${JOB_LOGS_LOCAL_DIR})" ]]; then
        echo "JOB_LOGS_LOCAL_DIR is empty. Skipping backup."
        return 0
    fi

    # Create backup directory if it doesn't exist
    if [[ ! -d "${JOB_LOGS_BACKUP_LOCAL_DIR}" ]]; then
        mkdir -p "${JOB_LOGS_BACKUP_LOCAL_DIR}"
    fi

    # Get the current date and time in the specified format
    local timestamp
    timestamp=$(date '+%Y-%m-%d_%H%M%S')

    # Set the backup destination path
    local backup_path="${JOB_LOGS_BACKUP_LOCAL_DIR}/${timestamp}_hilbert_job_logs"

    # Copy the current logs directory to the backup directory
    echo "Backing up job logs to ${backup_path}"
    cp -R "${JOB_LOGS_LOCAL_DIR}" "${backup_path}"

    if [[ $? -eq 0 ]]; then
        echo "Backup completed successfully."

        # Compress the newly created backup folder
        echo "Compressing backup folder ${backup_path}"
        tar -czf "${backup_path}.tar.gz" -C "${JOB_LOGS_BACKUP_LOCAL_DIR}" "$(basename ${backup_path})"

        if [[ $? -eq 0 ]]; then
            echo "Compression completed successfully."
        else
            echo "Failed to compress the backup folder."
            return 1
        fi
        echo "Backup completed successfully."

        # Empty the original job logs directory
        echo "Clearing contents of ${JOB_LOGS_LOCAL_DIR}"
        # Note: The :? syntax ensures that the variable is not empty or unset, 
        # preventing accidental deletion of unintended directories
        rm -r "${JOB_LOGS_LOCAL_DIR:?}/"*

        if [[ $? -eq 0 ]]; then
            echo "Contents of ${JOB_LOGS_LOCAL_DIR} cleared successfully."
        else
            echo "Failed to clear the contents of ${JOB_LOGS_LOCAL_DIR}."
            return 1
        fi
    else
        echo "Backup failed."
        return 1
    fi
}

cleanup_project_dir() {
    ssh $HPC_TOOLS_STORAGE_NODE -t "bash -ci 'base && home && cd $1 && cleanup'"
}

# Function to activate a specific HPC system
activate_hpc_system() {
    local requested_name="$1"
    if [[ -z "$requested_name" ]]; then
        echo "Error: No HPC system name provided."
        return 1
    fi

    # Convert to lowercase for comparison
    local lower_name=$(echo "$requested_name" | tr '[:upper:]' '[:lower:]')

    # Define supported systems (add more as needed)
    case "$lower_name" in
        hilbert)
            export ACTIVE_HPC_NAME="HILBERT"
            echo "Activated HPC system: Hilbert"
            ;;
        noctua2)
            export ACTIVE_HPC_NAME="NOCTUA2"
            echo "Activated HPC system: Noctua2"
            ;;
        *)
            echo "Error: Unknown HPC system '$requested_name'. Supported systems are: Hilbert, Noctua2"
            return 1
            ;;
    esac
}


# Function to display the usage of the tool
usage() {
    echo "Usage: hpc <command>"
    echo "Commands:"
    echo "  run   Run a python or bash script on the HPC"
    echo "  sync_project   Sync the local project with the HPC"
    echo "  sync_results   Sync the results from the HPC to the local machine"
    echo "  status   Check the status of the jobs and queues on the HPC"
    echo "  sync_job_logs   Sync the job logs from the HPC to the local machine"
    echo "  backup_job_logs   Backup the job logs on the local machine"
    echo "  setup_interactive   Setup an interactive session on the HPC"
    echo "  ssh  Connect to the HPC Login node"
    echo "  qi  Start an interactive session on the HPC"
    echo "  delete_job  Delete a job on the HPC"
    echo "  sync_hf  Sync the local huggingface models with the HPC"
    echo "  log Connect to the logs of running jobs on the HPC"
    echo "  cmd  Run a command on the HPC Login node"
    echo "  cleanup_project  Cleanup the project directory on the HPC"
    echo "  activate  Activate a specific HPC system (e.g., hilbert, noctua2)"
}

# Main script execution starts here
if [[ $# -lt 1 ]]; then
    usage
    exit 1
fi

COMMAND=$1
shift

case "$COMMAND" in
    run)
        sync_project_command &&
        run_command "$@"
        ;;
    sync_project)
        sync_project_command
        ;;
    sync_results)
        sync_results_command
        ;;
    status)
        status_command
        ;;
    sync_job_logs)
        sync_job_logs
        ;;
    backup_job_logs)
        backup_job_logs
        ;;
    setup_interactive)
        ssh $HPC_TOOLS_LOGIN_NODE -t "bash -ci 'base && clear && qi-setup $@'"
        ;;
    ssh)
        ssh $HPC_TOOLS_LOGIN_NODE
        ;;
    qi)
        start_interactive_command
        ;;
    log)
        connect_to_logs_command
        ;;
    delete_job)
        ssh $HPC_TOOLS_LOGIN_NODE -t "bash -ci 'base && clear && qdel $@'"
        ;;
    sync_hf)
        sync_hf_command
        ;;
    cmd)
        ssh $HPC_TOOLS_LOGIN_NODE -t "bash -ci '$@'"
        ;;
    cleanup_project)
        cleanup_project_dir "$@"
        ;;
    activate)
        activate_hpc_system "$@"
        ;;
    *)
        echo "Error: Unknown command '$COMMAND'"
        usage
        exit 1
        ;;
esac
