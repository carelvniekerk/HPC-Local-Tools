#compdef hpc

_hpc() {
    local -a commands
    commands=(
        'run:Run a python or bash script on the HPC'
        'sync_project:Sync the local project with the HPC'
        'sync_results:Sync the results from the HPC to the local machine'
        'status:Check the status of the jobs and queues on the HPC'
        'sync_job_logs:Sync the job logs from the HPC to the local machine'
        'backup_job_logs:Backup the job logs on the local machine into a folder with the current date'
        'setup_interactive:Setup an interactive session on the HPC'
        'ssh:Connect to the HPC Login node'
        'qi:Start an interactive session on the HPC'
        'delete_job:Delete a job on the HPC'
        'sync_hf:Sync the local huggingface models with the HPC'
        'log:Connect to the logs of running jobs on the HPC'
        'cmd:Run a command on the HPC Login node'
    )

    _arguments -C \
        "1:command:->command" \
        "*::args:->args"

    case $state in
        command)
            _describe 'command' commands
            ;;
        args)
            case $words[1] in
                run)
                    _files
                    ;;
                *)
                    # No further completion for other commands
                    ;;
            esac
            ;;
    esac
}

compdef _hpc hpc